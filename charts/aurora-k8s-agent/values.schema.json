{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["image", "rbac"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": {"type": "string", "minLength": 1},
        "tag": {"type": "string"},
        "pullPolicy": {"enum": ["Always", "IfNotPresent", "Never"]}
      }
    },
    "rbac": {
      "type": "object",
      "required": ["targetNamespaces"],
      "properties": {
        "create": {"type": "boolean"},
        "targetNamespaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "clusterWide": {"type": "boolean"}
      }
    },
    "secretName": {"type": "string"}
  }
}
