# nginx serves the built SPA and proxies /api (incl. the SSE stream) to the agent.
# The nginx image substitutes ${AURORA_API_UPSTREAM} from the environment at start
# (e.g. "my-release-api.default.svc:80"), producing a static upstream so no DNS
# resolver directive is needed.
server {
  listen 8080;
  server_name _;
  root /usr/share/nginx/html;
  index index.html;

  location /api/ {
    proxy_pass http://${AURORA_API_UPSTREAM};
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header Connection "";
    # Server-Sent Events: stream without buffering.
    proxy_buffering off;
    proxy_cache off;
    proxy_read_timeout 1h;
  }

  location / {
    try_files $uri $uri/ /index.html;
  }
}
